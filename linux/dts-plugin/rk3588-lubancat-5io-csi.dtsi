			/* MIPI CSI-2 bus endpoint */
			ov8858_dphy5_out: endpoint {
				remote-endpoint = <&dphy5_in_ov8858>;
				clock-lanes = <0>;
				data-lanes = <1 2>;
			};
		};
	};

